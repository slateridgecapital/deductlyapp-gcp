# Copy to .env.local and fill in values
# Google Maps Platform API key used for:
# - Places API (New): address autocomplete
# - Places API: place details (formatted address lookup)
# - Address Validation API: multi-unit detection (needsUnit)
GOOGLE_PLACES_API_KEY=


# Firebase Admin SDK – used to write lead submissions to Firestore
# Get values from your service account JSON (IAM > Service Accounts > Keys)
GCP_PROJECT_ID=deductlyapp
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
